
pipeline {
    agent {
        label 'yocto-build-node'
    }

    options {
        timeout(time: 4, unit: 'HOURS')
        timestamps ()
    }

    stages {

        stage('Clone Repositories') {
            steps {
                script {
                    echo "Cloning Poky repository..."

                    dir("${WORKSPACE}") {
                        git branch: 'main', url: 'https://github.com/YerawarPooja/yocto-build-demo.git'
                        sh """
                        cp /home/ubuntu/workspace/yocto-helloworld/meta-myhelloworld /tmp
                        """
                        git branch: 'kirkstone', url: 'https://git.yoctoproject.org/git/poky'
                        sh """
                        cp -r /tmp/meta-myhelloworld /home/ubuntu/workspace/yocto-helloworld/
                        """
                    }  
                }
            }
        }

        stage('Configure Build Environment and Build Image') {
            steps {
                script {
                    sh """
                    export TEMPLATECONF="${WORKSPACE}/poky/meta-myhelloworld/template/default"
                    source ${WORKSPACE}/poky/oe-init-build-env
                    bitbake core-image-minimal
                    """
                }
            }
        }
    }

    post {
      /*  always {

           
            cleanWs()
        } */
        success {
            echo "Yocto image build SUCCEEDED!"

        }
        failure {
            echo "Yocto image build FAILED!"
        }
        unstable {
            echo "Yocto image build UNSTABLE (e.g., some tests failed)."
        }
    }
}
